{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENT.md",
    "runs/LEADERBOARD.md"
  ],
  "permission": {
    "external_directory": "deny",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      ".venv/bin/python automation/*": "allow",
      ".venv/bin/python experiments/*": "allow"
    }
  }
}
